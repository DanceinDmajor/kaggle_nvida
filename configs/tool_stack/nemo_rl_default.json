{
  "tool": "NeMo RL",
  "objective": "sft",
  "launcher": "nemo_rl.recipes.nemotron",
  "inputs": {
    "train_manifest": "",
    "train_export": "",
    "eval_slice_dir": ""
  },
  "outputs": {
    "checkpoint_dir": "",
    "metrics_path": ""
  },
  "model": {
    "base_model": "nemotron-3-nano-30b",
    "adapter_type": "lora"
  },
  "trainer": {
    "learning_rate": 0.0001,
    "max_steps": 3200,
    "global_batch_size": 128,
    "micro_batch_size": 1
  },
  "rl": {
    "rollout_enabled": false,
    "algorithm": "grpo",
    "num_rollouts": 4
  }
}

