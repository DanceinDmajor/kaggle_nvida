{
  "tool": "DataDesigner",
  "recipe": "reasoning_multi_stage",
  "teacher_model": "teacher_placeholder",
  "generation_mode": "broad_coverage",
  "inputs": {
    "seed_manifest": "",
    "prompt_library_dir": "metadata/prompt_templates"
  },
  "outputs": {
    "generated_dir": "",
    "curated_candidate_manifest": ""
  },
  "sampling": {
    "num_generations_per_prompt": 4,
    "max_tokens": 2048,
